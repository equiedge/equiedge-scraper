{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/results.html", "dest": "/public/results.html" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "crons": [
    { "path": "/api/cron/trigger-weekly-results", "schedule": "0 22 * * 0" }
  ]
}
